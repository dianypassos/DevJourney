# ── Chave da API Groq (IA Astra) ──────────────────────────────────────────────
# Obtenha GRATUITAMENTE em: https://console.groq.com (sem cartão de crédito)
# Free tier: 30 req/min · 1 milhão de tokens/dia
GROQ_API_KEY=sua_chave_groq_aqui

# Modelo opcional (padrão: llama-3.1-8b-instant)
# Alternativa mais capaz: llama-3.3-70b-versatile (mesmo free tier)
# GROQ_MODEL=llama-3.1-8b-instant
